{
  "name": "openlayers-mcp-bridge",
  "version": "0.1.0",
  "description": "Browser SDK — AI agent controls OpenLayers map via WebSocket",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "ol": ">=9.0.0"
  },
  "devDependencies": {
    "ol": "^10.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "openlayers",
    "mcp",
    "ai",
    "map",
    "websocket",
    "bridge"
  ],
  "license": "MIT"
}
